# Copy to .env locally (never commit real secrets). See README.md and BANDWIDTH_RENDER_ENV.txt.

DATABASE_URL=postgresql://user:pass@localhost:5432/horizon

# Wasabi (portal files + optional app state snapshot)
WASABI_BUCKET=
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_REGION=us-east-1
WASABI_ENDPOINT=

# Portal: send file bytes client↔Wasabi, not through Node (production)
PORTAL_PROXY_FILE_DOWNLOAD=0
PORTAL_UPLOAD_PRESIGN=1

# Wasabi planner/app snapshot (see BANDWIDTH_RENDER_ENV.txt for full lean preset)
WASABI_STATE_ARCHIVE_SNAPSHOTS=0
WASABI_STATE_SNAPSHOT_GZIP=1
WASABI_STATE_WRITE_DEBOUNCE_MS=8000
WASABI_LATEST_STATE_CACHE_MS=30000

# Browser / desktop origins allowed to call the API (comma-separated, or * for dev only)
CORS_ORIGINS=https://your-portal.example.com

# After deploy: smoke test (Node 18+)
# HP_API_BASE=https://api.example.com HP_TOKEN=... HP_FILE_ID=<uuid> node scripts/smoke-portal-presign.mjs
# HP_CHECK_PROXY_DOWNLOAD=1 node scripts/smoke-portal-presign.mjs
