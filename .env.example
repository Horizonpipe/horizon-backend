# Copy to .env locally (never commit real secrets). See README.md and BANDWIDTH_RENDER_ENV.txt.

DATABASE_URL=postgresql://user:pass@localhost:5432/horizon

# Wasabi (portal files + optional app state snapshot)
WASABI_BUCKET=
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_REGION=us-east-1
WASABI_ENDPOINT=

# Portal: send file bytes client↔Wasabi, not through Node (production)
PORTAL_PROXY_FILE_DOWNLOAD=0
PORTAL_UPLOAD_PRESIGN=1

# Wasabi planner/app snapshot (see BANDWIDTH_RENDER_ENV.txt for full lean preset)
WASABI_STATE_ARCHIVE_SNAPSHOTS=0
WASABI_STATE_SNAPSHOT_GZIP=1
WASABI_STATE_WRITE_DEBOUNCE_MS=8000
WASABI_LATEST_STATE_CACHE_MS=30000

# Browser / desktop origins allowed to call the API (comma-separated, or * for dev only)
CORS_ORIGINS=https://your-portal.example.com

# SaaS multi-tenant (Horizonpipe cPanel)
# SAAS_SKIP_SUBSCRIPTION_CHECK=1
# SAAS_SKIP_WASABI_PROVISION=1
# SAAS_CPANEL_BASE_URL=https://your-static-site.example.com

# Platform release tracks (see docs/PLATFORM_RELEASE_MANAGEMENT.md)
# non-saas = your private PipeShare/PipeSync (direct deploy)
# saas = tenant platform (updates only via cPanel Platform updates)
HP_DEPLOYMENT_MODE=non-saas
# HP_RELEASE_ADMIN_TOKEN=   # optional: auto-register after publish-platform-release.sh
# HP_REPO_ROOT=/opt/horizon
# HP_PLATFORM_APPLY_SCRIPT=   # saas hosts only: path to deploy/saas/apply-platform-release.sh

# Stripe billing (Phase 2)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# Optional: comma-separated or JSON map of price ids (first / default used for checkout)
# STRIPE_PRICE_IDS=price_basic,price_pro
# STRIPE_SUCCESS_URL=https://your-static-site.example.com/horizonpipe-cpanel/billing.html?billing=success
# STRIPE_CANCEL_URL=https://your-static-site.example.com/horizonpipe-cpanel/billing.html?billing=canceled
# STRIPE_PORTAL_RETURN_URL=https://your-static-site.example.com/horizonpipe-cpanel/billing.html

# After deploy: smoke test (Node 18+)
# HP_API_BASE=https://api.example.com HP_TOKEN=... HP_FILE_ID=<uuid> node scripts/smoke-portal-presign.mjs
# HP_CHECK_PROXY_DOWNLOAD=1 node scripts/smoke-portal-presign.mjs

# Sign-up verification email (required for pipeshare.net Create account)
# GoDaddy mailbox: EmailVerification@pipeshare.net
# Option A — run on OVH: SMTP_PASS='...' bash deploy/ovh/setup-pipeshare-signup-smtp.sh
# Option B — discrete vars:
# SMTP_HOST=smtpout.secureserver.net
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=EmailVerification@pipeshare.net
# SMTP_PASS=
# SMTP_FROM=PipeShare <EmailVerification@pipeshare.net>
# SIGNUP_MAIL_FROM_NAME=PipeShare
