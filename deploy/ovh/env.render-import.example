# Paste ONLY these keys from Render Dashboard → horizon-backend → Environment
# Save as /opt/horizon/horizon-backend/.env.render-import (chmod 600)
# Then: bash deploy/ovh/import-render-env.sh
#
# Do NOT commit this file with real values.

# --- Wasabi (required for portal files + planner state snapshots) ---
WASABI_BUCKET=
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com

# Copy whatever *_PRIMARY_* flags Render has (match production exactly):
WASABI_ALL_READS_PRIMARY_ENABLED=
WASABI_ALL_READS_PRIMARY_STRICT=
WASABI_WRITES_PRIMARY_ENABLED=
WASABI_WRITES_PRIMARY_STRICT=
WASABI_RECORDS_PRIMARY_ENABLED=
WASABI_RECORDS_PRIMARY_STRICT=
WASABI_RECORD_DETAIL_PRIMARY_ENABLED=
WASABI_RECORD_DETAIL_PRIMARY_STRICT=
WASABI_AUTH_PRIMARY_ENABLED=
WASABI_SCOPES_PRIMARY_ENABLED=
WASABI_PERMISSIONS_TREE_PRIMARY_ENABLED=
WASABI_PORTAL_DATA_PRIMARY_ENABLED=
WASABI_AUTO_IMPORT_PRIMARY_ENABLED=
WASABI_OUTLOOK_PRIMARY_ENABLED=
WASABI_SIGNUP_PRIMARY_ENABLED=

# --- Stripe (use sk_live_* / whsec_* for production billing, or sk_test_* to stay in sandbox) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Portal bandwidth (usually same as Render — see BANDWIDTH_RENDER_ENV.txt) ---
PORTAL_PROXY_FILE_DOWNLOAD=0
PORTAL_UPLOAD_PRESIGN=1
PORTAL_RESUMABLE_PROXY_CHUNK=0
WASABI_STATE_ARCHIVE_SNAPSHOTS=0
WASABI_STATE_SNAPSHOT_GZIP=1
WASABI_STATE_SNAPSHOT_MS=3600000
WASABI_STATE_INCLUDE_ALL_TABLES=0
WASABI_SQL_MIRROR_ENABLED=0
WASABI_LATEST_STATE_CACHE_MS=30000
