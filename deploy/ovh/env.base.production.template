# PipeShare BASE (private) — /opt/horizon/horizon-backend/.env.base
# Copy from env.production.template, then set HP_DEPLOYMENT_MODE=non-saas and PORT=3000.

NODE_ENV=production
PORT=3000
HP_DEPLOYMENT_MODE=non-saas

DATABASE_URL=postgresql://horizon:CHANGE_ME@127.0.0.1:5432/horizon
DATABASE_SSL=0
PG_POOL_MAX=20

# pipeshare.live
SAAS_CPANEL_BASE_URL=https://pipeshare.live
CORS_ORIGINS=https://pipeshare.live,https://www.pipeshare.live

FRONTEND_STATIC_DIR=/opt/horizon/horizon-frontend
HP_REPO_ROOT=/opt/horizon

# Legacy shared bucket (portal-users, platform release publish)
WASABI_BUCKET=
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com

# Optional: SaaS bucket creds for publish artifacts only (same keys often work)
# SAAS_WASABI_BUCKET=saaspipeshare

PORTAL_PROXY_FILE_DOWNLOAD=0
PORTAL_UPLOAD_PRESIGN=1
PORTAL_RESUMABLE_PROXY_CHUNK=0

# Platform release PUBLISH (base only)
# HP_RELEASE_ADMIN_TOKEN=

# Cross-host support federation → SaaS API
# CP_SUPPORT_PRESENCE_PEER_SECRET=
# CP_SUPPORT_PRESENCE_PEER_URLS=https://pipeshare.net

HP_OVH_OPS_ENABLED=1
# HP_PM2_APP_NAME=horizon-backend-base
