# Copy to /opt/horizon/horizon-backend/.env on the OVH server.
# Fill secrets from Render Dashboard → Environment and your Stripe/Wasabi consoles.
# chmod 600 .env

NODE_ENV=production
PORT=3000

# After Postgres is restored locally:
DATABASE_URL=postgresql://horizon:CHANGE_ME@127.0.0.1:5432/horizon
DATABASE_SSL=0
PG_POOL_MAX=20

# Public site URL (no trailing slash) — used for CORS, Stripe redirects, cPanel
SAAS_CPANEL_BASE_URL=https://YOUR_DOMAIN
CORS_ORIGINS=https://YOUR_DOMAIN

# Frontend served from sibling repo (default if unset: ../horizon-frontend)
FRONTEND_STATIC_DIR=/opt/horizon/horizon-frontend

# Wasabi — copy from Render / local .env
WASABI_BUCKET=
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com

# Portal bandwidth (keep lean on dedicated — files bypass Node)
PORTAL_PROXY_FILE_DOWNLOAD=0
PORTAL_UPLOAD_PRESIGN=1
PORTAL_RESUMABLE_PROXY_CHUNK=0

# Wasabi snapshot lean preset (see BANDWIDTH_RENDER_ENV.txt)
WASABI_STATE_ARCHIVE_SNAPSHOTS=0
WASABI_STATE_SNAPSHOT_GZIP=1
WASABI_STATE_SNAPSHOT_MS=3600000
WASABI_STATE_WRITE_DEBOUNCE_MS=8000
WASABI_LATEST_STATE_CACHE_MS=30000
WASABI_SQL_MIRROR_ENABLED=0

# SaaS production — remove skip flags when Stripe + Wasabi provision are verified
# SAAS_SKIP_SUBSCRIPTION_CHECK=1
# SAAS_SKIP_WASABI_PROVISION=1

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_SUCCESS_URL=https://YOUR_DOMAIN/horizonpipe-cpanel/billing.html?billing=success
STRIPE_CANCEL_URL=https://YOUR_DOMAIN/horizonpipe-cpanel/billing.html?billing=canceled
STRIPE_PORTAL_RETURN_URL=https://YOUR_DOMAIN/horizonpipe-cpanel/billing.html

# Platform release separation (docs/PLATFORM_RELEASE_MANAGEMENT.md)
# OVH private instance = non-saas (default). Dedicated SaaS host = saas.
HP_DEPLOYMENT_MODE=non-saas
HP_REPO_ROOT=/opt/horizon
# HP_RELEASE_ADMIN_TOKEN=
# HP_PLATFORM_APPLY_SCRIPT=/opt/horizon/horizon-backend/deploy/saas/apply-platform-release.sh

# OVH ops console (Render-style metrics, logs, deploy, rollback)
HP_OVH_OPS_ENABLED=1
# GITHUB_WEBHOOK_SECRET=   # same secret on both GitHub repo webhooks → /ops/webhook/github
# HP_OVH_DEPLOY_REPOS=horizonpipe/horizon-frontend,horizonpipe/horizon-backend
# HP_OVH_DEPLOY_BRANCH=refs/heads/main
# HP_PM2_APP_NAME=horizon-backend
# HP_NGINX_ERROR_LOG=/var/log/nginx/horizon-error.log
